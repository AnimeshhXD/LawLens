# Security Configuration
SECRET_KEY=your-super-secure-secret-key-here-change-in-production-32chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=15

# Database
DATABASE_URL=sqlite:///./lawlens.db

# LLM Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
MAX_TOKENS=4000

# Rate Limiting
REDIS_URL=redis://localhost:6379
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# File Upload Security
MAX_FILE_SIZE_MB=10
ALLOWED_MIME_TYPES=["application/pdf","text/plain","application/vnd.openxmlformats-officedocument.wordprocessingml.document"]

# CORS Configuration
ALLOWED_ORIGINS=["http://localhost:3000","https://localhost:3000"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/lawlens.log
